# Caddy reverse proxy for HTTPS
# Usage: set DOMAIN env var to your domain, then enable the caddy service in docker-compose.yml
#
# For local development with self-signed certs:
#   DOMAIN=localhost
#
# For production with automatic Let's Encrypt:
#   DOMAIN=wealth.example.com

{$DOMAIN:localhost} {
	reverse_proxy app:8443
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
